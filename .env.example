# HopOff — app environment variables
# Copy to `.env` in this folder, fill in values, then restart Expo (`npx expo start`).
#
# Two setup modes:
#
#   LOCAL DEV (quick start)
#     Set client keys below. AI + YouTube call APIs directly from the app.
#     Good for testing on your machine — do NOT ship these keys in production builds.
#
#   PRODUCTION (recommended for TestFlight / store)
#     1. Deploy `/api` to Vercel — see docs/DEPLOY-API.md and api/.env.example
#     2. Set EXPO_PUBLIC_API_BASE_URL to your deployed URL
#     3. Omit EXPO_PUBLIC_OPENROUTER_API_KEY and EXPO_PUBLIC_YOUTUBE_API_KEY from the app
#     4. Keep EXPO_PUBLIC_NOTION_CLIENT_ID (public OAuth client id — not a secret)

# ── Backend proxy (production) ───────────────────────────────────────────────
# Your Vercel deployment URL, no trailing slash.
# When set, AI / YouTube / Notion token exchange use server routes instead of client keys.
EXPO_PUBLIC_API_BASE_URL=

# ── OpenRouter — goal polish + time insights ─────────────────────────────────
# Local dev: get a key at https://openrouter.ai/keys
# Production: set OPENROUTER_API_KEY on Vercel only (api/.env.example)
EXPO_PUBLIC_OPENROUTER_API_KEY=
# Model slug — must match an OpenRouter model id
EXPO_PUBLIC_OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ── YouTube Data API — video search in Collection tab ────────────────────────
# Local dev: Google Cloud Console → enable YouTube Data API v3 → create API key
# Production: set YOUTUBE_API_KEY on Vercel only
EXPO_PUBLIC_YOUTUBE_API_KEY=

# ── Notion OAuth — goals "Connect" ───────────────────────────────────────────
# Public client id from https://www.notion.so/my-integrations
# Secret goes on Vercel as NOTION_CLIENT_SECRET (never in the app)
# Redirect URL to register in Notion: hoptfoff://notion-callback
EXPO_PUBLIC_NOTION_CLIENT_ID=

# ── iOS Shortcuts — optional goals import (see docs/ios-shortcuts.md) ────────
EXPO_PUBLIC_SHORTCUT_REMINDERS_URL=
EXPO_PUBLIC_SHORTCUT_NOTES_URL=

# ── RevenueCat — subscriptions (optional in dev; local trial works without) ──
# Public SDK key from RevenueCat dashboard
EXPO_PUBLIC_REVENUECAT_API_KEY=
# Must match product ids in App Store Connect / Google Play / RevenueCat
EXPO_PUBLIC_RC_PRODUCT_MONTHLY=hopoff_monthly
EXPO_PUBLIC_RC_PRODUCT_ANNUAL=hopoff_annual
