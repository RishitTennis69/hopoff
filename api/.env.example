# HopOff — server environment variables (Vercel / serverless)
#
# Deploy the `/api` folder from the repo root to Vercel.
# Add these in: Vercel project → Settings → Environment Variables
#
# Then point the app at your deployment:
#   EXPO_PUBLIC_API_BASE_URL=https://your-project.vercel.app   (in app .env)
#
# See docs/DEPLOY-API.md for full deploy steps.

# ── OpenRouter — POST /api/openrouter ────────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional default model (client can override per request)
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── YouTube Data API — GET /api/youtube/search ───────────────────────────────
# Google Cloud Console → YouTube Data API v3 → API key
# Restrict key to YouTube Data API + your server IPs if possible
YOUTUBE_API_KEY=

# ── Notion OAuth — POST /api/notion/token ────────────────────────────────────
# https://www.notion.so/my-integrations → New integration → OAuth
# Client id also goes in app .env as EXPO_PUBLIC_NOTION_CLIENT_ID
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Meta ─────────────────────────────────────────────────────────────────────
# Your deployed Vercel URL (used as OpenRouter HTTP-Referer)
APP_URL=https://your-hopoff-api.vercel.app
