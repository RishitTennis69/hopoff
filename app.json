{
  "expo": {
    "name": "HopOff",
    "slug": "hoptfoff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hoptfoff",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "HopOff uses the microphone to transcribe your weekly goals.",
        "NSSpeechRecognitionUsageDescription": "HopOff transcribes your spoken goals into a weekly list.",
        "NSFamilyControlsUsageDescription": "HopOff uses Screen Time to enforce the app limits you set."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-video",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow HopOff to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow HopOff to transcribe your weekly goals."
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsTextWithMaxCount": 1
          },
          "androidIntentFilters": ["text/*"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
