{
  "expo": {
    "name": "HopOff",
    "slug": "hoptfoff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hoptfoff",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.kgrogerrr.hopoff",
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow HopOff to use the microphone for voice input.",
        "NSSpeechRecognitionUsageDescription": "Allow HopOff to transcribe your weekly goals.",
        "NSFamilyControlsUsageDescription": "HopOff uses Screen Time to enforce the app limits you set.",
        "LSApplicationQueriesSchemes": [
          "twitter",
          "tiktok",
          "snssdk1128",
          "youtube",
          "vnd.youtube",
          "instagram",
          "snapchat",
          "reddit",
          "fb"
        ]
      }
    },
    "android": {
      "package": "com.kgrogerrr.hopoff",
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.PACKAGE_USAGE_STATS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidPackageQueries.js",
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-video",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow HopOff to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow HopOff to transcribe your weekly goals."
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsTextWithMaxCount": 1
          },
          "iosAppGroupIdentifier": "group.com.kgrogerrr.hopoff",
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c3482638-8fee-44df-b63a-c0245700e49a"
      }
    }
  }
}
